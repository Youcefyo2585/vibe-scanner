# ── Required ─────────────────────────────────────────────────────────────────
# Serper.dev API key — drives the Google-index dork queries in Phase 1.
# Sign up: https://serper.dev (2,500 free credits).
SERPER_API_KEY=

# ── Recommended ──────────────────────────────────────────────────────────────
# Hugging Face access token — speeds up the first GLiNER model download
# (~700MB). Anonymous downloads work but are rate-limited.
# Create one: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Optional: GPT-4o risk assessments ────────────────────────────────────────
# When enabled, the dashboard fetches a 2-sentence CISO-style risk narrative
# from OpenAI for each discovered app. When disabled (default), the page's
# built-in rules engine writes the narrative locally — no key needed.
USE_AI=false
OPENAI_API_KEY=

# ── Server tuning ────────────────────────────────────────────────────────────
PORT=8080
# Comma-separated CORS origins. Leave blank for same-origin only.
ALLOWED_ORIGINS=

# ── Optional: AWS SSM Parameter Store backend ────────────────────────────────
# Set SSM_PREFIX (e.g. /vibe-scanner/prod/) to look up missing secrets in SSM
# instead of failing. Requires `pip install vibe-scanner[ssm]` (or just `boto3`).
SSM_PREFIX=
AWS_REGION=us-east-1
